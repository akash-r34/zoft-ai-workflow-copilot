{
  "name": "zoft-copilot",
  "private": true,
  "scripts": {
    "build":     "turbo run build",
    "dev":       "turbo run dev --parallel",
    "lint":      "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test":      "turbo run test",
    "demo":      "pnpm --filter @zoft/frontend dev"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
