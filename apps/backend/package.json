{
  "name": "@zoft/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build":       "tsc --project tsconfig.json",
    "dev":         "tsx watch src/index.ts",
    "typecheck":   "tsc --project tsconfig.json --noEmit",
    "lint":        "eslint src --ext .ts",
    "test":        "vitest run",
    "postinstall": "prisma generate",
    "db:migrate":  "prisma migrate dev",
    "db:seed":     "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@zoft/contract": "workspace:*",
    "fastify": "^4.26.0",
    "@fastify/cors": "^9.0.0",
    "pino": "^9.0.0",
    "@prisma/client": "^5.11.0",
    "ajv": "^8.12.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "vitest": "^1.4.0",
    "@vitest/coverage-v8": "^1.4.0",
    "prisma": "^5.11.0",
    "fast-check": "^3.15.0"
  }
}
